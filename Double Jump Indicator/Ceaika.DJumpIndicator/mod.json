{
	"Name": "Ceaika.DJumpIndicator",
	"Description": "it shows if u can double jump man what else do i say",
	"Version": "1.0.0",
	"LoadPriority": 1,
	"Dependencies": {
		"PLAYER_HAS_MOD_SETTINGS": "Mod Settings"
	},
	"ConVars": [
		{ "Name": "djump_indicator_enabled", "DefaultValue": "1" },
		{ "Name": "djump_indicator_width",   "DefaultValue": "280" },
		{ "Name": "djump_indicator_height",  "DefaultValue": "30" },
		{ "Name": "djump_indicator_pos_x",   "DefaultValue": "0.5" },
		{ "Name": "djump_indicator_pos_y",   "DefaultValue": "0.85" }
	],
	"Scripts": [
		{
			"Path": "client/cl_djump_indicator.gnut",
			"RunOn": "CLIENT",
			"ClientCallback": {
				"After": "DoubleJumpIndicator_Init"
			}
		},
		{
			"Path": "ui/djump_indicator_settings.nut",
			"RunOn": "UI",
			"UICallback": {
				"After": "DoubleJumpIndicatorSettings_Init"
			}
		}
	]
}
